{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "adamopolis-spotify-website",
  "compatibility_date": "2026-06-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/index.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
